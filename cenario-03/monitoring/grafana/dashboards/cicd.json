{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Status e métricas da pipeline CI/CD: status dos serviços, uptime e disponibilidade do Jenkins, SonarQube, Nexus e Artifactory.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔧 Status dos Serviços CI/CD",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "mappings": [ { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"app1-python\"}", "legendFormat": "App1 Python", "refId": "A" } ],
      "title": "App1 — Python",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "mappings": [ { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"app2-node\"}", "legendFormat": "App2 Node", "refId": "A" } ],
      "title": "App2 — Node.js",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "mappings": [ { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"redis\"}", "legendFormat": "Redis", "refId": "A" } ],
      "title": "Redis",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "mappings": [ { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"nginx\"}", "legendFormat": "Nginx", "refId": "A" } ],
      "title": "Nginx (HTTPS)",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📈 Disponibilidade (SLO)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "id": 10,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["mean"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "avg_over_time(up{job=\"app1-python\"}[24h])", "legendFormat": "App1 24h Uptime", "refId": "A" } ],
      "title": "App1 — Uptime 24h",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 6 },
      "id": 11,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["mean"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "avg_over_time(up{job=\"app2-node\"}[24h])", "legendFormat": "App2 24h Uptime", "refId": "A" } ],
      "title": "App2 — Uptime 24h",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "id": 12,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["mean"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "avg_over_time(up{job=\"nginx\"}[24h])", "legendFormat": "Nginx 24h Uptime", "refId": "A" } ],
      "title": "Nginx — Uptime 24h",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "id": 13,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["mean"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "avg_over_time(up{job=\"redis\"}[24h])", "legendFormat": "Redis 24h Uptime", "refId": "A" } ],
      "title": "Redis — Uptime 24h",
      "type": "gauge"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 102,
      "title": "📡 Histórico de Disponibilidade (Todos os Serviços)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 },
          "mappings": [ { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" } ],
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"app1-python\"}", "legendFormat": "App1 Python", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"app2-node\"}",   "legendFormat": "App2 Node",   "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"nginx\"}",       "legendFormat": "Nginx HTTPS",  "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "up{job=\"redis\"}",       "legendFormat": "Redis",        "refId": "D" }
      ],
      "title": "Histórico de UP/DOWN — Todos os Serviços",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 103,
      "title": "💡 Links de Acesso Rápido",
      "type": "row"
    },

    {
      "datasource": null,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "id": 30,
      "options": {
        "content": "## 🔗 Acesso Rápido\n\n| Serviço | URL | Credenciais |\n|---------|-----|-------------|\n| **Apps (HTTPS)** | https://localhost:8443/app1/ e /app2/ | — |\n| **Apps (HTTP→HTTPS redirect)** | http://localhost:8080 | — |\n| **Jenkins** | http://localhost:8088 | admin / admin123 |\n| **SonarQube (SAST)** | http://localhost:9000 | admin / admin123 |\n| **Nexus** | http://localhost:8081 | admin / admin123 |\n| **Artifactory** | http://localhost:8082 | admin / password |\n| **Prometheus** | http://localhost:9090 | — |\n\n> ⚠️ Certificado TLS self-signed — aceite a exceção de segurança no navegador ou adicione o certificado em `nginx/certs/nginx.crt` como CA confiável.",
        "mode": "markdown"
      },
      "title": "Serviços e URLs",
      "type": "text"
    }

  ],
